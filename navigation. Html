<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Navigation Bar Example</title>
<style>
    body{
        margin:0;
        font-family:Arial, sans-serif;
        background:#f4f4f4;
    }

    .navbar{
        background-color:#333;
        overflow:hidden;
        display:flex;
        justify-content:center;
    }

    .navbar a{
        color:white;
        text-decoration:none;
        padding:16px 20px;
        display:block;
        transition:0.3s;
    }

    .navbar a:hover{
        background-color:#575757;
        color:yellow;
    }

    .content{
        text-align:center;
        padding:50px;
    }
</style>
</head>
<body>

<div class="navbar">
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Services</a>
    <a href="#">Contact</a>
</div>

<div class="content">
    <h1>Navigation Bar Output</h1>
    <p>This is a simple navigation bar using HTML and CSS.</p>
</div>

</body>
</html>
