<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#0d1117;
    color:white;
}

.title{
    text-align:center;
    margin:50px 0 30px;
}

.title h1{
    font-size:55px;
    font-weight:bold;
}

.title span{
    color:#67d4ff;
}

.tech-card{
    background:#161b22;
    border-radius:15px;
    text-align:center;
    padding:30px;
    transition:0.3s;
    height:100%;
}

.tech-card:hover{
    transform:translateY(-5px);
}

.tech-card img{
    width:70px;
    height:70px;
    object-fit:contain;
    margin-bottom:15px;
}

.nav-pills .nav-link{
    color:white;
    background:#1c2333;
    border-radius:0;
}

.nav-pills .nav-link.active{
    background:#67d4ff;
    color:black;
}
</style>
</head>

<body>

<div class="container">

    <div class="title">
        <h1>My <span>Tech Stack</span></h1>
    </div>

    <ul class="nav nav-pills justify-content-center mb-5">
        <li class="nav-item">
            <button class="nav-link active">All (12)</button>
        </li>
        <li class="nav-item">
            <button class="nav-link">Languages</button>
        </li>
        <li class="nav-item">
            <button class="nav-link">Tools</button>
        </li>
        <li class="nav-item">
            <button class="nav-link">Libraries</button>
        </li>
        <li class="nav-item">
            <button class="nav-link">Databases</button>
        </li>
    </ul>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/6132/6132222.png">
                <h4>C</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/6132/6132221.png">
                <h4>C++</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/5968/5968350.png">
                <h4>Python</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/226/226777.png">
                <h4>Java</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/732/732212.png">
                <h4>HTML</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/732/732190.png">
                <h4>CSS</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/5968/5968672.png">
                <h4>MySQL</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="tech-card">
                <img src="https://cdn-icons-png.flaticon.com/512/919/919851.png">
                <h4>React</h4>
            </div>
        </div>

    </div>

</div>

</body>
</html>